{
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @finpilot/api prisma generate && pnpm --filter @finpilot/web build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "apps/api/prisma/**"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
