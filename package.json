{
  "name": "finpilot-financeiro",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @finpilot/api prisma generate",
    "db:migrate": "pnpm --filter @finpilot/api prisma migrate dev",
    "db:seed": "pnpm --filter @finpilot/api prisma db seed",
    "db:studio": "pnpm --filter @finpilot/api prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  }
}